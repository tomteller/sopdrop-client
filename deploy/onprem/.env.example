# Sopdrop on-prem deployment — copy to .env and fill in.

# --- Postgres ---
POSTGRES_DB=sopdrop
POSTGRES_USER=sopdrop
# REQUIRED. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- App secrets ---
# REQUIRED. >=32 chars. Generate: openssl rand -hex 32
JWT_SECRET=

# --- URLs / CORS ---
# Public address artists hit from Houdini. Use a hostname your LAN resolves
# (e.g. an A record for sopdrop.lan) so you can move the box later without
# rotating every workstation's config.
PUBLIC_URL=http://sopdrop.lan:4800
WEB_URL=http://sopdrop.lan:4800
CORS_ORIGINS=http://sopdrop.lan:4800,http://localhost:5173

# --- Network bind ---
# Host port the API is published on. 4800 matches the client default.
BIND_HOST=0.0.0.0
BIND_PORT=4800

# --- Account policy (internal team, no public signup) ---
# Skip the email-verification gate so artists can publish immediately after
# creating an account. Pair with BETA_MODE=true if you want invite-only signup.
SKIP_EMAIL_VERIFICATION=true
BETA_MODE=false

# --- Trust-LAN auth (recommended for internal LAN deployments) ---
# When TRUST_LAN_AUTH=true, the server accepts requests with no Bearer token
# if they carry an X-Sopdrop-User header. The user is auto-created on first
# sight (no password, no token, no Login dance for artists). Identity comes
# from the workstation's OS username, sent automatically by the client when
# Local-only mode + HTTP team mode are both on.
#
# This is the right setting for a trusted internal LAN — artists don't need
# to onboard with tokens, the audit log still attributes actions to a real
# username, and per-user features (favorites, recents) work normally.
#
# DO NOT enable this on a server reachable from the public internet — it
# means anyone who can hit the API can claim any identity.
TRUST_LAN_AUTH=true

# Optional: auto-add every trust-LAN user to this team (idempotent
# upsert on every request, so both new and existing users get added).
# Set this to your team's slug to skip the per-artist
# `INSERT INTO team_members` chore. Leave blank to manage membership
# manually. The team must exist before the server starts — create it
# with deploy/onprem/scripts/create-team.sh.
# TRUST_LAN_DEFAULT_TEAM=my-team

# --- Rate limits (per-IP unless noted) ---
# All limits are env-tunable; defaults are shown. Setting MAX=0 disables
# that limiter entirely. The global generalLimiter is automatically
# skipped for trust-LAN requests (X-Sopdrop-User header + TRUST_LAN_AUTH
# on), so a busy team doesn't hit 429s on reads from the team library.
# Tune these up if you have a larger team or a chatty client.
#
# RATE_GENERAL_MAX=100              # global fallback, per minute
# RATE_GENERAL_WINDOW_MS=60000
# RATE_DOWNLOAD_MAX=60              # asset downloads, per minute
# RATE_DOWNLOAD_WINDOW_MS=60000
# RATE_UPLOAD_MAX=10                # asset uploads, per hour, per user
# RATE_UPLOAD_WINDOW_MS=3600000
# RATE_VERSION_MAX=20               # version publishes, per hour, per user
# RATE_VERSION_WINDOW_MS=3600000
# RATE_SHARE_MAX=10                 # 24h share links, per hour, per user
# RATE_SHARE_WINDOW_MS=3600000
# RATE_TOKEN_MAX=5                  # API token mints, per hour, per user
# RATE_TOKEN_WINDOW_MS=3600000
# RATE_LOGIN_MAX=5                  # login attempts, per 15min, per IP
# RATE_LOGIN_WINDOW_MS=900000
# RATE_REGISTER_MAX=3               # account creations, per hour, per IP
# RATE_REGISTER_WINDOW_MS=3600000
# RATE_OAUTH_MAX=15                 # OAuth callbacks, per 15min, per IP
# RATE_OAUTH_WINDOW_MS=900000
# RATE_PASSWORD_CHANGE_MAX=3        # password changes, per hour, per user
# RATE_PASSWORD_CHANGE_WINDOW_MS=3600000

# --- Optional OAuth (leave blank for username/password only) ---
GOOGLE_CLIENT_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
