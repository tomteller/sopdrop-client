# Sopdrop on-prem deployment — copy to .env and fill in.

# --- Postgres ---
POSTGRES_DB=sopdrop
POSTGRES_USER=sopdrop
# REQUIRED. Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# --- App secrets ---
# REQUIRED. >=32 chars. Generate: openssl rand -hex 32
JWT_SECRET=

# --- URLs / CORS ---
# Public address artists hit from Houdini. Use a hostname your LAN resolves
# (e.g. an A record for sopdrop.lan) so you can move the box later without
# rotating every workstation's config.
PUBLIC_URL=http://sopdrop.lan:4800
WEB_URL=http://sopdrop.lan:4800
CORS_ORIGINS=http://sopdrop.lan:4800,http://localhost:5173

# --- Network bind ---
# Host port the API is published on. 4800 matches the client default.
BIND_HOST=0.0.0.0
BIND_PORT=4800

# --- Account policy (internal team, no public signup) ---
# Skip the email-verification gate so artists can publish immediately after
# creating an account. Pair with BETA_MODE=true if you want invite-only signup.
SKIP_EMAIL_VERIFICATION=true
BETA_MODE=false

# --- Trust-LAN auth (recommended for internal LAN deployments) ---
# When TRUST_LAN_AUTH=true, the server accepts requests with no Bearer token
# if they carry an X-Sopdrop-User header. The user is auto-created on first
# sight (no password, no token, no Login dance for artists). Identity comes
# from the workstation's OS username, sent automatically by the client when
# Local-only mode + HTTP team mode are both on.
#
# This is the right setting for a trusted internal LAN — artists don't need
# to onboard with tokens, the audit log still attributes actions to a real
# username, and per-user features (favorites, recents) work normally.
#
# DO NOT enable this on a server reachable from the public internet — it
# means anyone who can hit the API can claim any identity.
TRUST_LAN_AUTH=true

# --- Optional OAuth (leave blank for username/password only) ---
GOOGLE_CLIENT_ID=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
