# ===========================================
# Sopdrop Server Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# -------------------------------------------
# Server Configuration
# -------------------------------------------
NODE_ENV=development
PORT=4848
HOST=0.0.0.0
# Fly.io uses port 8080 — set PORT=8080 in production

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
# Option 1: Connection URL (preferred for Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# SSL is opt-in. Set DB_SSL=true for managed/cloud Postgres (Neon, Supabase, RDS).
# Leave unset/false for local Postgres or the on-prem postgres:16-alpine image,
# which has SSL disabled by default.
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED only applies once DB_SSL=true; set 'false' for
# providers with self-signed certs (e.g., Neon).
# DB_SSL_REJECT_UNAUTHORIZED=false

# Option 2: Individual vars (for local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sopdrop
DB_USER=postgres
# REQUIRED: Set a strong password
DB_PASSWORD=your-secure-database-password

# -------------------------------------------
# Authentication (REQUIRED - NO DEFAULTS)
# -------------------------------------------
# JWT_SECRET must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-64-character-hex-string-here

# -------------------------------------------
# OAuth (at least one provider required for login)
# -------------------------------------------
# Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:5173/login/discord/callback

# Google
GOOGLE_CLIENT_ID=your-google-client-id

# -------------------------------------------
# File Storage
# -------------------------------------------
# Local filesystem (development default)
LIBRARY_PATH=./library
UPLOAD_DIR=./library/nodes
HDA_DIR=./library/hdas
TEMP_DIR=./library/temp

# Cloudflare R2 (production — leave blank to use local filesystem)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=sopdrop
# R2_PUBLIC_URL=https://cdn.sopdrop.com

# -------------------------------------------
# URLs
# -------------------------------------------
# Public URL where the API is accessible
PUBLIC_URL=http://localhost:4848

# Web frontend URL (for CORS and redirects)
WEB_URL=http://localhost:5173

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4848

# -------------------------------------------
# Email (for verification emails)
# -------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@sopdrop.com

# -------------------------------------------
# Development/Debug Options
# -------------------------------------------
# Set to 'true' to log SQL queries
DEBUG_SQL=false

# Skip email verification requirement (dev only)
# SKIP_EMAIL_VERIFICATION=true

# -------------------------------------------
# Production Checklist
# -------------------------------------------
# Before deploying to production, ensure:
# [ ] NODE_ENV=production
# [ ] DATABASE_URL points to Neon/Supabase with SSL
# [ ] JWT_SECRET is a secure random string (64+ chars recommended)
# [ ] R2 credentials configured for file storage
# [ ] PUBLIC_URL points to your domain with HTTPS
# [ ] CORS_ORIGINS only includes your trusted domains
# [ ] Discord OAuth configured with production redirect URI
# [ ] SMTP configured for email verification
